general {
  colors = true
  interval = 5
  color_good     = "#a6e3a1"
  color_degraded = "#f9e2af"
  color_bad      = "#f38ba8"
}

order += "disk /"
order += "memory"
order += "cpu_usage"
order += "tztime local"

disk "/" {
  format = " %avail"
}

memory {
  format = " %used / %total"
  threshold_degraded = "10%"
}

cpu_usage {
  format = " %usage"
}

tztime local {
  format = " %H:%M %d/%m"
}
